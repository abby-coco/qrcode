.template-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.template-header__icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 8rpx;
}

.template-header__title {
  font-size: 34rpx;
  font-weight: 600;
}

.template-tip {
  display: block;
  font-size: 24rpx;
  color: #888888;
  line-height: 1.6;
  margin-bottom: 24rpx;
  padding: 16rpx 20rpx;
  background: #f5f6fa;
  border-radius: 12rpx;
}

.respondent-preview {
  margin-bottom: 24rpx;
}

.respondent-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.respondent-tag {
  padding: 8rpx 20rpx;
  background: #f0edff;
  color: #7c6cf0;
  border-radius: 24rpx;
  font-size: 24rpx;
}

.input-label {
  margin-top: 20rpx;
}

.input-label:first-of-type {
  margin-top: 0;
}
