.launch {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(160deg, #7c6cf0 0%, #a78bfa 55%, #f5f6fa 100%);
  padding: 48rpx;
  box-sizing: border-box;
}

.launch__brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 120rpx;
}

.launch__logo-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.launch__logo {
  width: 72rpx;
  height: 72rpx;
}

.launch__name {
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.launch__loading {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.launch__spinner {
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.35);
  border-top-color: #ffffff;
  border-radius: 50%;
  animation: launch-spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

.launch__text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.92);
}

@keyframes launch-spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
