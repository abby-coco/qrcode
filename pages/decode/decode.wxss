.scan-area {
  text-align: center;
  padding: 48rpx 32rpx;
}

.scan-icon {
  font-size: 96rpx;
  margin-bottom: 16rpx;
}

.scan-title {
  font-size: 34rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.scan-desc {
  font-size: 26rpx;
  color: #999999;
  display: block;
  margin-bottom: 32rpx;
}

.result-box {
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  word-break: break-all;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.result-actions {
  display: flex;
  gap: 16rpx;
}

.result-actions button {
  flex: 1;
}
