.preview-area {
  width: 100%;
  height: 400rpx;
  background: #f5f6fa;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.preview-img {
  width: 100%;
  height: 100%;
}

.preview-placeholder {
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}

.preview-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 12rpx;
}
