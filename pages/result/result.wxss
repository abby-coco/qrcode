.qr-card {
  text-align: center;
  padding: 40rpx 32rpx;
}

.qr-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 32rpx;
}

.qr-wrap {
  display: flex;
  justify-content: center;
  margin-bottom: 16rpx;
  padding: 32rpx;
  background: #fafafa;
  border-radius: 20rpx;
}

.qr-canvas {
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.wxacode-image {
  width: 280px;
  height: 280px;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.qr-hint {
  font-size: 24rpx;
  color: #999999;
}

.cloud-tip {
  margin-top: 24rpx;
  padding: 20rpx;
  background: #f0edff;
  border-radius: 16rpx;
  text-align: left;
}

.cloud-tip__badge {
  display: block;
  font-size: 22rpx;
  color: #7c6cf0;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.cloud-tip__text {
  font-size: 24rpx;
  color: #666666;
  line-height: 1.5;
}

.raw-card {
  margin-bottom: 24rpx;
}

.raw-card__label {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 12rpx;
}

.raw-card__content {
  font-size: 26rpx;
  color: #333333;
  line-height: 1.6;
  word-break: break-all;
  display: block;
}

.action-grid {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 16rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-item__icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.action-item__label {
  font-size: 24rpx;
  color: #666666;
}

.action-item:active {
  opacity: 0.7;
}
