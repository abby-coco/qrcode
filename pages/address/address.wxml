<view class="container">
  <view class="card">
    <text class="section-title">地址信息</text>
    <text class="tip">扫码可打开地图导航</text>

    <button class="btn-secondary" bindtap="chooseLocation" style="margin-bottom:24rpx;">📍 从地图选择</button>

    <text class="input-label">地点名称</text>
    <input class="input-box" placeholder="例如：XX公司" placeholder-class="input-placeholder" model:value="{{name}}" />

    <text class="input-label">详细地址</text>
    <textarea class="textarea-box" placeholder="请输入详细地址" placeholder-class="input-placeholder" model:value="{{address}}" />

    <text class="input-label">纬度 (可选)</text>
    <input class="input-box" placeholder="自动填充" placeholder-class="input-placeholder" model:value="{{latitude}}" />

    <text class="input-label">经度 (可选)</text>
    <input class="input-box" placeholder="自动填充" placeholder-class="input-placeholder" model:value="{{longitude}}" />
  </view>

  <button class="btn-primary" bindtap="generate">生成地址二维码</button>
</view>
