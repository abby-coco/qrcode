.summary-card {
  text-align: center;
  margin-bottom: 24rpx;
}

.summary-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.summary-count {
  display: block;
  font-size: 26rpx;
  color: #7c6cf0;
  margin-bottom: 24rpx;
}

.loading, .error-text {
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}

.submission-card {
  margin-bottom: 20rpx;
}

.submission-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.submission-index {
  font-size: 28rpx;
  font-weight: 600;
  color: #7c6cf0;
}

.submission-time {
  font-size: 22rpx;
  color: #999999;
}

.submission-row {
  display: flex;
  gap: 16rpx;
  padding: 10rpx 0;
}

.submission-label {
  flex: 0 0 140rpx;
  font-size: 24rpx;
  color: #888888;
}

.submission-value {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
  word-break: break-all;
}

.empty-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #bbbbbb;
  padding: 0 40rpx;
}
