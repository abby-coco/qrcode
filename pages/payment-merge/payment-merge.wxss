.add-btns {
  display: flex;
  gap: 16rpx;
}

.add-btns button {
  flex: 1;
}

.code-list {
  margin-top: 8rpx;
}

.code-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.code-item__img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 16rpx;
}

.code-item__info {
  flex: 1;
  font-size: 28rpx;
}

.code-item__del {
  color: #ef4444;
  font-size: 28rpx;
  padding: 8rpx 16rpx;
}

.option-row {
  display: flex;
  gap: 16rpx;
}

.option-chip {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #f5f6fa;
  font-size: 26rpx;
  color: #666666;
}

.option-chip--active {
  background: #fef3c7;
  color: #f59e0b;
  font-weight: 500;
}
