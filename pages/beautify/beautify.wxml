<view class="container">
  <canvas
    canvas-id="previewCanvas"
    class="preview-canvas-hidden"
    style="width: {{canvasSize}}px; height: {{canvasSize}}px;"
  />

  <view class="card preview-card" wx:if="{{qrData}}">
    <text class="section-title">实时预览</text>
    <view class="preview-wrap">
      <image
        wx:if="{{previewImage}}"
        class="preview-image"
        src="{{previewImage}}"
        mode="aspectFit"
      />
      <view wx:else class="preview-placeholder">预览生成中...</view>
    </view>
    <text class="preview-hint">调整下方选项，二维码会立即更新</text>
  </view>

  <view class="card">
    <text class="section-title">前景色</text>
    <view class="color-row">
      <view
        class="color-dot {{foregroundColor === item ? 'color-dot--active' : ''}}"
        wx:for="{{presetColors}}"
        wx:key="*this"
        style="background: {{item}};"
        bindtap="selectPresetColor"
        data-color="{{item}}"
      />
    </view>
    <view class="custom-color-row">
      <view class="color-swatch" style="background: {{foregroundColor}};"></view>
      <input
        class="custom-color-input"
        value="{{fgHexInput}}"
        maxlength="7"
        placeholder="#000000"
        bindinput="onFgHexInput"
        bindblur="applyFgHex"
      />
    </view>
  </view>

  <view class="card">
    <text class="section-title">背景色</text>
    <view class="custom-color-row">
      <view class="color-swatch" style="background: {{backgroundColor}}; border: 1rpx solid #eeeeee;"></view>
      <input
        class="custom-color-input"
        value="{{bgHexInput}}"
        maxlength="7"
        placeholder="#ffffff"
        bindinput="onBgHexInput"
        bindblur="applyBgHex"
      />
    </view>
  </view>

  <view class="card">
    <text class="section-title">中心 Logo</text>
    <view class="logo-section" wx:if="{{logoPath}}">
      <image class="logo-preview" src="{{logoPath}}" mode="aspectFill" />
      <button class="btn-secondary" bindtap="removeLogo">移除 Logo</button>
    </view>
    <button class="btn-outline" wx:else bindtap="chooseLogo">选择中心图片</button>

    <text class="input-label" style="margin-top:24rpx;">Logo 形状</text>
    <view class="option-row">
      <view
        class="option-chip {{logoShape === item.value ? 'option-chip--active' : ''}}"
        wx:for="{{shapeOptions}}"
        wx:key="value"
        bindtap="selectShape"
        data-value="{{item.value}}"
      >{{item.label}}</view>
    </view>

    <text class="input-label">Logo 大小 ({{logoSize}}%)</text>
    <slider min="10" max="30" value="{{logoSize}}" bindchange="onLogoSizeChange" bindchanging="onLogoSizeChanging" activeColor="#7c6cf0" />
  </view>

  <view class="card">
    <text class="section-title">纠错级别</text>
    <view class="option-row">
      <view
        class="option-chip {{errorCorrectionLevel === item.value ? 'option-chip--active' : ''}}"
        wx:for="{{levelOptions}}"
        wx:key="value"
        bindtap="selectLevel"
        data-value="{{item.value}}"
      >{{item.label}}</view>
    </view>
  </view>

  <button class="btn-primary" bindtap="saveConfig">保存美化设置</button>
</view>
