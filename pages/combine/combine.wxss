.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.type-item {
  width: calc(33.33% - 12rpx);
  padding: 28rpx 0;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
}

.type-item__icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.type-item__label {
  font-size: 26rpx;
  color: #333333;
}

.type-item:active {
  opacity: 0.8;
}

.item-list {
  margin-top: 8rpx;
}

.item-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.item-row:last-child {
  border-bottom: none;
}

.item-row__left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.item-row__icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.item-row__name {
  font-size: 28rpx;
  font-weight: 500;
  display: block;
}

.item-row__preview {
  font-size: 24rpx;
  color: #999999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

.item-row__actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #f5f6fa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #666666;
  text-align: center;
  line-height: 56rpx;
}

.action-btn--del {
  color: #ef4444;
}

.empty-hint {
  text-align: center;
  padding: 48rpx 32rpx;
}

.empty-hint__text {
  color: #999999;
  font-size: 26rpx;
}

.footer-actions {
  padding: 16rpx 0 32rpx;
}

.footer-actions .btn-primary[disabled] {
  opacity: 0.5;
}
