.hero-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.hero-left {
  flex: 1;
}

.hero-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.hero-card {
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
}

.hero-card--primary {
  background: linear-gradient(145deg, #7c6cf0 0%, #a78bfa 50%, #c4b5fd 100%);
  padding: 32rpx 28rpx;
  min-height: 320rpx;
  display: flex;
  flex-direction: column;
  color: #ffffff;
}

.hero-card__glow {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 160rpx;
  height: 160rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
}

.hero-card__icon {
  width: 72rpx;
  height: 72rpx;
  margin-bottom: 16rpx;
}

.hero-card__title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.hero-card__desc {
  font-size: 22rpx;
  opacity: 0.85;
  line-height: 1.4;
  flex: 1;
}

.hero-card__btn {
  display: inline-block;
  background: rgba(255, 255, 255, 0.25);
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  align-self: flex-start;
  margin-top: 16rpx;
}

.hero-card--orange {
  background: #fff7ed;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  flex: 1;
}

.hero-card--purple {
  background: #f0edff;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  flex: 1;
}

.hero-card--blue {
  background: #eff6ff;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  flex: 1;
}

.hero-card--green {
  background: #f0fdf4;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
  flex: 1;
}

.hero-card__small-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.hero-card__small-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
}

.hero-card:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.static-section {
  margin-bottom: 24rpx;
}

.decode-link {
  font-size: 24rpx;
  color: #7c6cf0;
}

.static-input-wrap {
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
}

.static-placeholder {
  color: #bbbbbb;
  font-size: 28rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  column-gap: 12rpx;
  margin-top: 8rpx;
  width: 100%;
}

.quick-grid__item {
  min-width: 0;
}
