.preview-area {
  width: 100%;
  height: 300rpx;
  background: #f5f6fa;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.preview-placeholder, .video-selected {
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}

.preview-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 12rpx;
}

.decode-link {
  font-size: 24rpx;
  color: #7c6cf0;
}

.option-row {
  display: flex;
  gap: 16rpx;
}

.option-chip {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #f5f6fa;
  font-size: 26rpx;
  color: #666666;
}

.option-chip--active {
  background: #fce7f3;
  color: #ec4899;
  font-weight: 500;
}
