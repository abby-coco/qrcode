.preview-area {
  width: 100%;
  height: 300rpx;
  background: #f5f6fa;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.preview-placeholder, .video-selected {
  text-align: center;
  color: #999999;
  font-size: 28rpx;
}

.preview-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 12rpx;
}

.decode-link {
  font-size: 24rpx;
  color: #7c6cf0;
}

