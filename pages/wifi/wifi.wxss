.tip {
  font-size: 24rpx;
  color: #22c55e;
  display: block;
  margin-bottom: 24rpx;
}

.option-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.option-chip {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #f5f6fa;
  font-size: 26rpx;
  color: #666666;
}

.option-chip--active {
  background: #ecfdf5;
  color: #22c55e;
  font-weight: 500;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
  font-size: 28rpx;
}
