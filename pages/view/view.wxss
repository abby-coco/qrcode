.container {
  padding: 32rpx;
}

.loading, .error {
  text-align: center;
  padding: 120rpx 32rpx;
  color: #999999;
  font-size: 28rpx;
}

.error__icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 16rpx;
}

.error__text {
  line-height: 1.6;
}

.view-title {
  font-size: 34rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 24rpx;
  color: #1a1a1a;
}

.view-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #333333;
  word-break: break-all;
  white-space: pre-wrap;
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}
