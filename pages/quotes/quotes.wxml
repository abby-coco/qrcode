<view class="container">
  <view class="category-bar">
    <view
      class="category-chip {{activeCategory === item.key ? 'category-chip--active' : ''}}"
      wx:for="{{categories}}"
      wx:key="key"
      bindtap="switchCategory"
      data-key="{{item.key}}"
    >
      <text>{{item.icon}} {{item.label}}</text>
    </view>
  </view>

  <view class="card">
    <view class="quote-item" wx:for="{{currentItems}}" wx:key="text">
      <text class="quote-item__text">{{item.text}}</text>
      <text class="quote-item__author" wx:if="{{item.author}}">—— {{item.author}}</text>
      <view class="quote-item__actions">
        <text class="quote-action" bindtap="copyText" data-text="{{item.text}}">复制</text>
        <text class="quote-action quote-action--primary" bindtap="generateQR" data-text="{{item.text}}">生成二维码</text>
      </view>
    </view>
  </view>
</view>
