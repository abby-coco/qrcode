.template-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.template-item:last-child {
  border-bottom: none;
}

.template-item__thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.template-item__emoji {
  font-size: 48rpx;
}

.template-item__info {
  flex: 1;
  overflow: hidden;
}

.template-item__title {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  display: block;
  margin-bottom: 6rpx;
}

.template-item__desc {
  font-size: 24rpx;
  color: #999999;
  display: block;
}

.template-item__arrow {
  font-size: 36rpx;
  color: #cccccc;
  margin-left: 12rpx;
}

.template-item:active {
  opacity: 0.7;
}
