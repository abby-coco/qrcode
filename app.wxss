page {
  background-color: #f5f6fa;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.container {
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

/* 通用卡片 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title-row .section-title {
  margin-bottom: 0;
}

.section-more {
  font-size: 24rpx;
  color: #999999;
}

/* 输入框 */
.input-box {
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  color: #1a1a1a;
  min-height: 88rpx;
  line-height: 1.5;
  display: block;
}

.textarea-box {
  background: #f5f6fa;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  width: 100%;
  min-height: 200rpx;
  box-sizing: border-box;
  color: #1a1a1a;
  line-height: 1.6;
  display: block;
}

.input-placeholder {
  color: #bbbbbb;
  font-size: 28rpx;
}

.input-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
  display: block;
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #7c6cf0 0%, #a78bfa 100%);
  color: #ffffff;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  padding: 24rpx 0;
  text-align: center;
  border: none;
  line-height: 1.4;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #f0edff;
  color: #7c6cf0;
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  text-align: center;
  border: none;
}

.btn-secondary::after {
  border: none;
}

.btn-outline {
  background: transparent;
  color: #7c6cf0;
  border: 2rpx solid #7c6cf0;
  border-radius: 48rpx;
  font-size: 28rpx;
  padding: 20rpx 0;
  text-align: center;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.tag-purple { background: #f0edff; color: #7c6cf0; }
.tag-orange { background: #fff7ed; color: #f59e0b; }
.tag-green { background: #f0fdf4; color: #22c55e; }
.tag-blue { background: #eff6ff; color: #3b82f6; }
.tag-red { background: #fef2f2; color: #ef4444; }

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 0;
  color: #999999;
}

.empty-state .empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}
